class Solution {
private:
    int timer = 1;
    
    void dfs(int node, int parent, vector<int> &vis, int tin[], int low[], 
             vector<int> &mark, vector<int> adj[]) {
        vis[node] = 1;
        tin[node] = low[node] = timer;
        timer++;
        int child = 0;
        
        for (auto it : adj[node]) {
            if (it == parent) continue; // Don't look back at the parent
            
            if (!vis[it]) {
                dfs(it, node, vis, tin, low, mark, adj);
                
                // When coming back from the DFS, update the low value
                low[node] = min(low[node], low[it]);
                
                // Case 1: Check articulation point condition for non-root
                if (low[it] >= tin[node] && parent != -1) {
                    mark[node] = 1; // Use a mark array to avoid duplicates
                }
                child++;
            } else {
                // Back-edge found: update low value of current node
                low[node] = min(low[node], tin[it]);
            }
        }
        
        // Case 2: Check articulation point condition for the root
        if (child > 1 && parent == -1) {
            mark[node] = 1;
        }
    }

public:
    vector<int> articulationPoints(int V, vector<vector<int>>& edges) {
        // 1. Build the adjacency list
        vector<int> adj[V];
        for (auto it : edges) {
            adj[it[0]].push_back(it[1]);
            adj[it[1]].push_back(it[0]);
        }
        
        vector<int> vis(V, 0);
        int tin[V];
        int low[V];
        
        // We use a mark array because a node might be flagged as an 
        // articulation point multiple times by different children subtrees.
        vector<int> mark(V, 0); 
        
        // 2. Handle potentially disconnected components
        for (int i = 0; i < V; i++) {
            if (!vis[i]) {
                dfs(i, -1, vis, tin, low, mark, adj);
            }
        }
        
        // 3. Collect the marked articulation points
        vector<int> ans;
        for (int i = 0; i < V; i++) {
            if (mark[i] == 1) {
                ans.push_back(i);
            }
        }
        
        if (ans.empty()) return {-1};
        
        return ans;
    }
};

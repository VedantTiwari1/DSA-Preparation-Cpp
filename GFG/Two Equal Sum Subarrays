class Solution {
  public:
    bool canSplit(vector<int>& arr) {
        long long totalSum = 0;
        
        // Step 1: Calculate total sum
        for (int x : arr) {
            totalSum += x;
        }
        
        // Step 2: If total sum is odd, we can't split it equally
        if (totalSum % 2 != 0) {
            return false;
        }
        
        long long target = totalSum / 2;
        long long runningSum = 0;
        
        // Step 3: Check if any prefix sum equals the target
        for (int i = 0; i < arr.size(); i++) {
            runningSum += arr[i];
            if (runningSum == target) {
                return true;
            }
        }
        
        return false;
    }
};

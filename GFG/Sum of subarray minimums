#include <vector>
#include <stack>

class Solution {
public:
    int sumSubMins(std::vector<int>& arr) {
        int n = arr.size();
        std::vector<int> left(n), right(n);
        std::stack<int> s;

        // Find distance to Previous Smaller Element
        for (int i = 0; i < n; ++i) {
            while (!s.empty() && arr[s.top()] >= arr[i]) s.pop();
            left[i] = s.empty() ? i + 1 : i - s.top();
            s.push(i);
        }

        // Clear stack for next pass
        while (!s.empty()) s.pop();

        // Find distance to Next Smaller Element
        for (int i = n - 1; i >= 0; --i) {
            while (!s.empty() && arr[s.top()] > arr[i]) s.pop();
            right[i] = s.empty() ? n - i : s.top() - i;
            s.push(i);
        }

        long long totalSum = 0;
        for (int i = 0; i < n; ++i) {
            // totalSum += (element value) * (subarrays where it's minimum)
            totalSum += (long long)arr[i] * left[i] * right[i];
        }

        return (int)totalSum;
    }
};

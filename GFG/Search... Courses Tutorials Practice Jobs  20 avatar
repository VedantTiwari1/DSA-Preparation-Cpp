class Solution {
public:
    bool isPower(int x, int y) {
        // Edge case: Any number to the power of 0 is 1
        if (y == 1) return true;
        
        // Edge case: 1 to any power is always 1
        if (x == 1) return (y == 1);

        long long res = x; 
        // Use long long to prevent overflow during multiplication
        while (res <= y) {
            if (res == y) return true;
            
            // Optimization: if x is 10 and y is 1000, 
            // res becomes 10 -> 100 -> 1000
            res *= x;
        }

        return false;
    }
};

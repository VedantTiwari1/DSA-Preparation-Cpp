#include <vector>
#include <cmath>
#include <iostream>

using namespace std;

class Solution {
public:
    int countSpanTree(int n, vector<vector<int>>& edges) {
        if (n <= 1) return 1;

        // 1. Build the Laplacian Matrix
        vector<vector<double>> laplacian(n, vector<double>(n, 0));
        for (auto& edge : edges) {
            int u = edge[0], v = edge[1];
            laplacian[u][u]++;
            laplacian[v][v]++;
            laplacian[u][v]--;
            laplacian[v][u]--;
        }

        // 2. Create the reduced matrix (remove last row and last column)
        int size = n - 1;
        vector<vector<double>> matrix(size, vector<double>(size));
        for (int i = 0; i < size; i++) {
            for (int j = 0; j < size; j++) {
                matrix[i][j] = laplacian[i][j];
            }
        }

        // 3. Calculate Determinant using Gaussian Elimination
        double det = 1.0;
        for (int i = 0; i < size; i++) {
            int pivot = i;
            for (int j = i + 1; j < size; j++) {
                if (abs(matrix[j][i]) > abs(matrix[pivot][i])) pivot = j;
            }

            if (abs(matrix[pivot][i]) < 1e-9) return 0; // Graph is not connected

            swap(matrix[i], matrix[pivot]);
            if (i != pivot) det *= -1;

            det *= matrix[i][i];

            for (int j = i + 1; j < size; j++) {
                double factor = matrix[j][i] / matrix[i][i];
                for (int k = i + 1; k < size; k++) {
                    matrix[j][k] -= factor * matrix[i][k];
                }
            }
        }

        return (int)round(abs(det));
    }
};

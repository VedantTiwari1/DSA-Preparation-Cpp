class Solution {
public:
    int maxArea(vector<int>& height) {
        int left = 0;
        int right = height.size() - 1;
        int max_area = 0;
        
        while (left < right) {
            // Calculate width as the number of bars strictly between left and right
            int width = right - left - 1;
            
            // Area is limited by the shorter bar
            int current_area = min(height[left], height[right]) * width;
            max_area = max(max_area, current_area);
            
            // Move the pointer of the shorter bar to look for a potentially taller boundary
            if (height[left] < height[right]) {
                left++;
            } else {
                right--;
            }
        }
        
        return max_area;
    }
};

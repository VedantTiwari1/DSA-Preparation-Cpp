class Solution {
public:
    int maxWater(vector<int> &arr) {
        int n = arr.size();
        if (n <= 2) return 0; // Need at least 3 bars to trap water

        int left = 0, right = n - 1;
        int leftMax = 0, rightMax = 0;
        int totalWater = 0;

        while (left <= right) {
            if (arr[left] <= arr[right]) {
                // If the current left bar is taller than the previous max, update it
                if (arr[left] >= leftMax) {
                    leftMax = arr[left];
                } else {
                    // Otherwise, it can definitely trap water based on leftMax
                    totalWater += leftMax - arr[left];
                }
                left++;
            } else {
                // If the right bar is smaller, the bottleneck is on the right
                if (arr[right] >= rightMax) {
                    rightMax = arr[right];
                } else {
                    totalWater += rightMax - arr[right];
                }
                right--;
            }
        }

        return totalWater;
    }
};

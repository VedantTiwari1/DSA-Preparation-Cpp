class Solution {
public:
    string largestSwap(string &s) {
        int n = s.length();
        // Step 1: Record the last occurrence of each digit
        vector<int> last(10, -1);
        for (int i = 0; i < n; ++i) {
            last[s[i] - '0'] = i;
        }

        // Step 2: Traverse the string to find the first swappable digit
        for (int i = 0; i < n; ++i) {
            // Check for digits larger than the current one, starting from 9
            for (int d = 9; d > (s[i] - '0'); --d) {
                // If a larger digit exists later in the string, swap them
                if (last[d] > i) {
                    swap(s[i], s[last[d]]);
                    return s; // At most one swap
                }
            }
        }
        
        return s; // Return original if no beneficial swap is found
    }
};

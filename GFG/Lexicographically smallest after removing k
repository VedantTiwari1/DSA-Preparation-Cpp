class Solution {
  public:
    string lexicographicallySmallest(string s, int k) {
        int n = s.length();
        
        // Step 1: Correct the value of k
        // A number n is a power of 2 if (n & (n-1)) == 0
        if (n > 0 && (n & (n - 1)) == 0) {
            k /= 2;
        } else {
            k *= 2;
        }
        
        // Step 2: If we must remove all characters (or more), it results in an empty string
        if (k >= n) {
            return "-1";
        }
        
        // Step 3: Monotonic Stack logic
        string result = "";
        
        for (char c : s) {
            // While the stack is not empty, we have removals left, 
            // and the current char is smaller than the top of the stack
            while (!result.empty() && k > 0 && result.back() > c) {
                result.pop_back();
                k--;
            }
            result.push_back(c);
        }
        
        // If we still need to remove characters (e.g., string was already sorted)
        // Remove them from the back of the result
        while (k > 0 && !result.empty()) {
            result.pop_back();
            k--;
        }
        
        // Final safety check
        if (result.empty()) {
            return "-1";
        }
        
        return result;
    }
};

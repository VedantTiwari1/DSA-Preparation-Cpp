class Solution {
public:
    bool canSeatAllPeople(int k, vector<int>& seats) {
        int n = seats.size();
        
        // Early exit if no one needs to be seated
        if (k == 0) return true;
        
        for (int i = 0; i < n; i++) {
            if (seats[i] == 0) {
                // Check if the left neighbor is empty (or if it's the first seat)
                bool left_empty = (i == 0 || seats[i - 1] == 0);
                
                // Check if the right neighbor is empty (or if it's the last seat)
                bool right_empty = (i == n - 1 || seats[i + 1] == 0);
                
                if (left_empty && right_empty) {
                    // Seat the person and mark the seat as occupied
                    seats[i] = 1; 
                    k--;
                    
                    // If everyone is successfully seated, stop early
                    if (k == 0) return true;
                }
            }
        }
        
        // If the loop finishes and k is still greater than 0, we failed to seat everyone
        return k <= 0;
    }
};

class Solution {
public:
    int maxSubarrayXOR(vector<int>& arr, int k) {
        int n = arr.size();
        int current_xor = 0;
        
        // 1. Compute the XOR sum of the first window of size k
        for (int i = 0; i < k; i++) {
            current_xor ^= arr[i];
        }

        int max_xor = current_xor;

        // 2. Slide the window
        for (int i = k; i < n; i++) {
            // XORing with the element leaving the window removes it
            // XORing with the new element adds it
            current_xor ^= arr[i - k]; // Remove leftmost
            current_xor ^= arr[i];     // Add rightmost
            
            max_xor = max(max_xor, current_xor);
        }

        return max_xor;
    }
};

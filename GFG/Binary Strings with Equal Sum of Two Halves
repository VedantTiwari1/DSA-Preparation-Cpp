class Solution {
private:
    long long MOD = 1e9 + 7;
    
    // Function to calculate (base^exp) % MOD in O(log exp) time
    long long power(long long base, long long exp) {
        long long res = 1;
        base = base % MOD;
        while (exp > 0) {
            if (exp % 2 == 1) res = (res * base) % MOD;
            base = (base * base) % MOD;
            exp /= 2;
        }
        return res;
    }
    
    // Function to find modular inverse of n under modulo MOD
    long long modInverse(long long n) {
        return power(n, MOD - 2);
    }
    
public:
    int computeValue(int n) {
        long long num = 1;
        long long den = 1;
        
        // We calculate (2n)! / n! which is (n+1)*(n+2)...*(2n) for the numerator
        // and n! which is 1*2...*n for the denominator.
        for (int i = 1; i <= n; i++) {
            num = (num * (n + i)) % MOD;
            den = (den * i) % MOD;
        }
        
        // Result is (numerator * modular_inverse(denominator)) % MOD
        return (num * modInverse(den)) % MOD;
    }
};

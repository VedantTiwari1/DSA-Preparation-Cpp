#include <vector>
#include <string>

using namespace std;

// Define the structure for a Trie Node
struct TrieNode {
    TrieNode* children[26];
    int count; // Tracks how many words share this character path
    
    TrieNode() {
        count = 0;
        for (int i = 0; i < 26; ++i) {
            children[i] = nullptr;
        }
    }
};

class Solution {
    TrieNode* root;

    // Helper function to insert a word into the Trie
    void insert(const string& word) {
        TrieNode* curr = root;
        for (char c : word) {
            int index = c - 'a';
            if (curr->children[index] == nullptr) {
                curr->children[index] = new TrieNode();
            }
            curr = curr->children[index];
            curr->count++; // Increment count for every word passing through
        }
    }

    // Helper function to find the shortest unique prefix for a word
    string getUniquePrefix(const string& word) {
        TrieNode* curr = root;
        string prefix = "";
        
        for (char c : word) {
            int index = c - 'a';
            prefix += c;
            curr = curr->children[index];
            
            // If we reach a node with count 1, it's a unique prefix
            if (curr->count == 1) {
                break;
            }
        }
        return prefix;
    }

public:
    vector<string> findPrefixes(vector<string>& arr) {
        root = new TrieNode();
        
        // Step 1: Build the Trie with all words
        for (const string& word : arr) {
            insert(word);
        }
        
        // Step 2: Query the Trie to find prefixes
        vector<string> result;
        for (const string& word : arr) {
            result.push_back(getUniquePrefix(word));
        }
        
        return result;
    }
};

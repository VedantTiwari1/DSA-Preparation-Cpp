class Solution {
public:
    bool findRotation(vector<vector<int>>& mat, vector<vector<int>>& target) {
        int n = mat.size();
        
        // Check for all 4 possible rotations (0, 90, 180, 270 degrees)
        for (int k = 0; k < 4; k++) {
            if (mat == target) return true;
            
            // Rotate mat by 90 degrees clockwise
            // 1. Transpose
            for (int i = 0; i < n; i++) {
                for (int j = i + 1; j < n; j++) {
                    swap(mat[i][j], mat[j][i]);
                }
            }
            // 2. Reverse each row
            for (int i = 0; i < n; i++) {
                reverse(mat[i].begin(), mat[i].end());
            }
        }
        
        return false;
    }
};

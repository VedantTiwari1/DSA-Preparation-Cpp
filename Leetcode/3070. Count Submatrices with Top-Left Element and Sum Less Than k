class Solution {
public:
    int countSubmatrices(vector<vector<int>>& grid, int k) {
        int rows = grid.size();
        int cols = grid[0].size();
        int count = 0;

        for (int i = 0; i < rows; i++) {
            for (int j = 0; j < cols; j++) {
                // Add the sum from the top cell
                if (i > 0) grid[i][j] += grid[i - 1][j];
                
                // Add the sum from the left cell
                if (j > 0) grid[i][j] += grid[i][j - 1];
                
                // Subtract the overlapping diagonal cell (added twice)
                if (i > 0 && j > 0) grid[i][j] -= grid[i - 1][j - 1];

                // Check if the current prefix sum is within the limit
                if (grid[i][j] <= k) {
                    count++;
                } else {
                    // Optimization: since grid values are non-negative (usually), 
                    // if grid[i][j] > k, larger submatrices in this row/col 
                    // might also exceed k.
                    // Note: Only break if you are sure elements are non-negative.
                }
            }
        }

        return count;
    }
};

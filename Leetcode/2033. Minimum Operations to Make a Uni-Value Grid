#include <vector>
#include <algorithm>
#include <cmath>

class Solution {
public:
    int minOperations(std::vector<std::vector<int>>& grid, int x) {
        std::vector<int> nums;
        int m = grid.size();
        int n = grid[0].size();
        
        // 1. Flatten the grid and check for feasibility
        int firstRemainder = grid[0][0] % x;
        for (int i = 0; i < m; ++i) {
            for (int j = 0; j < n; ++j) {
                if (grid[i][j] % x != firstRemainder) {
                    return -1;
                }
                nums.push_back(grid[i][j]);
            }
        }
        
        // 2. Sort to find the median
        std::sort(nums.begin(), nums.end());
        int median = nums[nums.size() / 2];
        
        // 3. Calculate total operations to reach the median
        int operations = 0;
        for (int val : nums) {
            operations += std::abs(val - median) / x;
        }
        
        return operations;
    }
};

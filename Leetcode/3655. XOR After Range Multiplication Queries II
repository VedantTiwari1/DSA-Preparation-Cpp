class Solution {
public:
    int xorAfterQueries(vector<int>& nums, vector<vector<int>>& queries) {
        int n = nums.size();
        const int MOD = 1e9 + 7;
        int T = sqrt(n); 
        
        // Fast exponentiation to find the modular inverse
        auto power = [&](long long base, int exp) {
            long long res = 1;
            base %= MOD;
            while (exp > 0) {
                if (exp % 2 == 1) res = (res * base) % MOD;
                base = (base * base) % MOD;
                exp /= 2;
            }
            return res;
        };
        
        auto modInverse = [&](int n) {
            return power(n, MOD - 2);
        };

        // Group queries with small step sizes
        vector<vector<vector<int>>> small_k(T);
        
        for (const auto& q : queries) {
            int l = q[0], r = q[1], k = q[2], v = q[3];
            if (k >= T) {
                // Large k: Simulate directly since jumps are large and few
                for (int idx = l; idx <= r; idx += k) {
                    nums[idx] = (1LL * nums[idx] * v) % MOD;
                }
            } else {
                small_k[k].push_back(q);
            }
        }
        
        // Small k: Batch process using a multiplicative difference array
        vector<long long> diff(n, 1);
        for (int k = 1; k < T; k++) {
            if (small_k[k].empty()) continue;
            
            for (const auto& q : small_k[k]) {
                int l = q[0], r = q[1], v = q[3];
                
                // Calculate the exact index where the sequence drops out of bounds
                int jumps = (r - l) / k;
                int stop_idx = l + (jumps + 1) * k;
                
                diff[l] = (diff[l] * v) % MOD;
                if (stop_idx < n) {
                    diff[stop_idx] = (diff[stop_idx] * modInverse(v)) % MOD;
                }
            }
            
            // Propagate multipliers via prefix product and apply to nums
            for (int i = 0; i < n; i++) {
                if (i >= k) {
                    diff[i] = (diff[i] * diff[i - k]) % MOD;
                }
                nums[i] = (1LL * nums[i] * diff[i]) % MOD;
            }
            
            // Reset diff array for the next step size
            for (int i = 0; i < n; i++) {
                diff[i] = 1;
            }
        }
        
        // Final bitwise XOR computation
        int ans = 0;
        for (int x : nums) {
            ans ^= x;
        }
        return ans;
    }
};

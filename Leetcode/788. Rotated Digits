class Solution {
public:
    int rotatedDigits(int n) {
        int count = 0;
        for (int i = 1; i <= n; ++i) {
            if (isGood(i)) {
                count++;
            }
        }
        return count;
    }

private:
    bool isGood(int num) {
        bool hasChangingDigit = false;
        while (num > 0) {
            int digit = num % 10;
            // Rule 1: Contains invalid digits
            if (digit == 3 || digit == 4 || digit == 7) {
                return false;
            }
            // Rule 3: Contains digits that rotate to something different
            if (digit == 2 || digit == 5 || digit == 6 || digit == 9) {
                hasChangingDigit = true;
            }
            num /= 10;
        }
        // Must contain at least one changing digit to be "different"
        return hasChangingDigit;
    }
};

class Solution {
public:
    vector<vector<int>> reverseSubmatrix(vector<vector<int>>& grid, int x, int y, int k) {
        int top = x;
        int bottom = x + k - 1;

        while (top < bottom) {
            // Swap the elements in the specific column range [y, y + k - 1]
            for (int j = y; j < y + k; ++j) {
                int temp = grid[top][j];
                grid[top][j] = grid[bottom][j];
                grid[bottom][j] = temp;
            }
            // Move pointers toward the center
            top++;
            bottom--;
        }

        return grid;
    }
};

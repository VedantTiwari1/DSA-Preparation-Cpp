#include <vector>

using namespace std;

class Solution {
    int n;
    int LOG;
    vector<vector<int>> adj;
    vector<vector<int>> up;
    vector<int> depth;

    // DFS to initialize depths and the binary lifting table
    void dfs(int u, int p, int d) {
        up[u][0] = p;
        depth[u] = d;
        for (int i = 1; i < LOG; i++) {
            if (up[u][i - 1] != -1) {
                up[u][i] = up[up[u][i - 1]][i - 1];
            } else {
                up[u][i] = -1;
            }
        }
        for (int v : adj[u]) {
            if (v != p) {
                dfs(v, u, d + 1);
            }
        }
    }

    // Function to find the Lowest Common Ancestor (LCA)
    int getLCA(int u, int v) {
        if (depth[u] < depth[v]) {
            swap(u, v);
        }
        int diff = depth[u] - depth[v];
        
        // Level the nodes
        for (int i = 0; i < LOG; i++) {
            if ((diff >> i) & 1) {
                u = up[u][i];
            }
        }
        if (u == v) return u;
        
        // Climb up together
        for (int i = LOG - 1; i >= 0; i--) {
            if (up[u][i] != up[v][i]) {
                u = up[u][i];
                v = up[v][i];
            }
        }
        return up[u][0];
    }

    // Modular exponentiation to handle large answers
    long long power(long long base, long long exp) {
        long long res = 1;
        base %= 1000000007;
        while (exp > 0) {
            if (exp % 2 == 1) res = (res * base) % 1000000007;
            base = (base * base) % 1000000007;
            exp /= 2;
        }
        return res;
    }

public:
    vector<int> assignEdgeWeights(vector<vector<int>>& edges, vector<vector<int>>& queries) {
        n = edges.size() + 1;
        LOG = 0;
        while ((1 << LOG) <= n) LOG++;
        
        adj.assign(n + 1, vector<int>());
        up.assign(n + 1, vector<int>(LOG, -1));
        depth.assign(n + 1, 0);
        
        // Build the tree
        for (auto& edge : edges) {
            adj[edge[0]].push_back(edge[1]);
            adj[edge[1]].push_back(edge[0]);
        }
        
        // Root the tree at node 1 (1-indexed as per problem constraints)
        dfs(1, -1, 0);
        
        vector<int> ans;
        ans.reserve(queries.size());
        
        for (auto& q : queries) {
            int u = q[0];
            int v = q[1];
            
            if (u == v) {
                ans.push_back(0);
            } else {
                int lca = getLCA(u, v);
                int dist = depth[u] + depth[v] - 2 * depth[lca];
                
                // The answer is 2^(dist - 1) % (10^9 + 7)
                ans.push_back(power(2, dist - 1));
            }
        }
        
        return ans;
    }
};

class Solution {
public:
    int numberOfSpecialChars(string word) {
        vector<bool> lower(26, false);
        vector<bool> upper(26, false);
        
        // Traverse the string and mark occurrences
        for (char c : word) {
            if (islower(c)) {
                lower[c - 'a'] = true;
            } else if (isupper(c)) {
                upper[c - 'A'] = true;
            }
        }
        
        int specialCount = 0;
        
        // Count letters that appeared in both arrays
        for (int i = 0; i < 26; i++) {
            if (lower[i] && upper[i]) {
                specialCount++;
            }
        }
        
        return specialCount;
    }
};

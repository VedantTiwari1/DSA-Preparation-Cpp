#include <vector>
#include <algorithm>
#include <unordered_map>

using namespace std;

class Solution {
public:
    vector<int> arrayRankTransform(vector<int>& arr) {
        // Step 1: Create a copy and sort it
        vector<int> sorted_arr = arr;
        sort(sorted_arr.begin(), sorted_arr.end());
        
        // Step 2: Map each unique element to its rank
        unordered_map<int, int> rank_map;
        int rank = 1;
        for (int num : sorted_arr) {
            // Only assign a rank if we haven't seen this number before
            if (rank_map.find(num) == rank_map.end()) {
                rank_map[num] = rank;
                rank++;
            }
        }
        
        // Step 3: Replace elements in the original array with their rank
        for (int i = 0; i < arr.size(); ++i) {
            arr[i] = rank_map[arr[i]];
        }
        
        return arr;
    }
};

class Solution {
public:
    int maxDistance(vector<int>& nums1, vector<int>& nums2) {
        int i = 0, j = 0;
        int maxDist = 0;
        int n1 = nums1.size();
        int n2 = nums2.size();

        while (i < n1 && j < n2) {
            // Check if the current pair is valid
            if (nums1[i] <= nums2[j]) {
                // Update the maximum distance found so far
                maxDist = max(maxDist, j - i);
                // Move j forward to try and increase the distance
                j++;
            } else {
                // If nums1[i] > nums2[j], we need a smaller nums1[i]
                // Moving i forward gives us a smaller or equal value
                i++;
            }
        }

        return maxDist;
    }
};

class Solution {
public:
    int numberOfSubmatrices(vector<vector<char>>& grid) {
        int rows = grid.size();
        int cols = grid[0].size();
        
        // 2D Prefix sums for (Count X - Count Y) and (Total count of X)
        vector<vector<int>> diff(rows + 1, vector<int>(cols + 1, 0));
        vector<vector<int>> hasX(rows + 1, vector<int>(cols + 1, 0));
        
        int result = 0;
        
        for (int i = 0; i < rows; ++i) {
            for (int j = 0; j < cols; ++j) {
                int val = (grid[i][j] == 'X') ? 1 : (grid[i][j] == 'Y' ? -1 : 0);
                int xCount = (grid[i][j] == 'X') ? 1 : 0;
                
                // Standard 2D Prefix Sum Formula: 
                // Current = Top + Left - Diagonal + Value
                diff[i+1][j+1] = diff[i][j+1] + diff[i+1][j] - diff[i][j] + val;
                hasX[i+1][j+1] = hasX[i][j+1] + hasX[i+1][j] - hasX[i][j] + xCount;
                
                // Check conditions: Equal frequency (diff == 0) and at least one 'X'
                if (diff[i+1][j+1] == 0 && hasX[i+1][j+1] > 0) {
                    result++;
                }
            }
        }
        
        return result;
    }
};

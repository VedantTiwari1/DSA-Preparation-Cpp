class Robot {
private:
    int w, h;
    int perimeter;
    int pos; 
    bool hasMoved; // Added flag to track if we've ever taken a step

public:
    Robot(int width, int height) {
        w = width;
        h = height;
        perimeter = 2 * (w - 1) + 2 * (h - 1);
        pos = 0;
        hasMoved = false; // Initialize to false
    }
    
    void step(int num) {
        // We only move if num > 0, so flag it
        if (num > 0) {
            hasMoved = true;
        }
        pos = (pos + num) % perimeter;
    }
    
    vector<int> getPos() {
        if (pos < w) {
            return {pos, 0}; 
        } else if (pos < w + h - 1) {
            return {w - 1, pos - (w - 1)}; 
        } else if (pos < 2 * w + h - 2) {
            return {w - 1 - (pos - (w + h - 2)), h - 1}; 
        } else {
            return {0, h - 1 - (pos - (2 * w + h - 3))}; 
        }
    }
    
    string getDir() {
        // Check if we are at the origin AND if we've actually moved
        if (pos == 0) {
            return hasMoved ? "South" : "East";
        } 
        
        // The rest of the directions remain the same
        if (pos < w) {
            return "East";
        } else if (pos < w + h - 1) {
            return "North";
        } else if (pos < 2 * w + h - 2) {
            return "West";
        } else {
            return "South";
        }
    }
};

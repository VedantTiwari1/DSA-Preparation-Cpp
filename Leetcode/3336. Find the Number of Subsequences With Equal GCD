#include <vector>
#include <numeric>
#include <algorithm>

using namespace std;

class Solution {
public:
    int subsequencePairCount(vector<int>& nums) {
        const int MOD = 1e9 + 7;
        
        // Find the maximum value to bound our DP table dimensions
        int max_val = 0;
        for (int x : nums) {
            max_val = max(max_val, x);
        }
        
        // dp[g1][g2] stores the number of valid pairs of subsequences 
        // with GCDs g1 and g2 respectively.
        vector<vector<long long>> dp(max_val + 1, vector<long long>(max_val + 1, 0));
        dp[0][0] = 1; // Base case: both subsequences are empty
        
        for (int x : nums) {
            // Copy current state to represent the "Skip" choice
            vector<vector<long long>> next_dp = dp; 
            
            for (int g1 = 0; g1 <= max_val; ++g1) {
                for (int g2 = 0; g2 <= max_val; ++g2) {
                    if (dp[g1][g2] > 0) {
                        
                        // Choice 2: Include x in the first subsequence
                        int next_g1 = (g1 == 0) ? x : std::gcd(g1, x);
                        next_dp[next_g1][g2] = (next_dp[next_g1][g2] + dp[g1][g2]) % MOD;
                        
                        // Choice 3: Include x in the second subsequence
                        int next_g2 = (g2 == 0) ? x : std::gcd(g2, x);
                        next_dp[g1][next_g2] = (next_dp[g1][next_g2] + dp[g1][g2]) % MOD;
                    }
                }
            }
            dp = next_dp;
        }
        
        // Sum up all cases where both subsequences have the same GCD
        // We start from g = 1 to ensure the subsequences are non-empty
        long long ans = 0;
        for (int g = 1; g <= max_val; ++g) {
            ans = (ans + dp[g][g]) % MOD;
        }
        
        return ans;
    }
};

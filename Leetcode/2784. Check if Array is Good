class Solution {
public:
    bool isGood(vector<int>& nums) {
        int m = nums.size();
        if (m < 2) return false; // base[1] is the smallest valid array [1, 1]

        sort(nums.begin(), nums.end());
        
        // The maximum element 'n' should be m - 1
        int n = m - 1;

        // Check 1 to n-1
        for (int i = 0; i < n - 1; i++) {
            if (nums[i] != i + 1) return false;
        }

        // Check if the last two elements are both equal to n
        return nums[n - 1] == n && nums[n] == n;
    }
};

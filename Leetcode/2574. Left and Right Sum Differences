class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        int rightSum = 0;
        int leftSum = 0;
        vector<int> answer;
        
        // Calculate the total sum of the array
        for (int num : nums) {
            rightSum += num;
        }
        
        // Calculate differences dynamically
        for (int i = 0; i < nums.size(); i++) {
            rightSum -= nums[i]; // Remove current element from right sum
            answer.push_back(abs(leftSum - rightSum));
            leftSum += nums[i];  // Add current element to left sum for the next iteration
        }
        
        return answer;
    }
};
